{
	"name": "@aionbuilders/nabu",
	"version": "0.1.0-alpha.6",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && npm run prepack",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"prepack": "bunx svelte-kit sync && bunx svelte-package && bunx publint",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"test:unit": "vitest run",
		"test:unit:watch": "vitest",
		"test:e2e": "playwright test",
		"test": "bun run test:unit && bun run test:e2e"
	},
	"files": [
		"dist",
		"!dist/**/*.test.*",
		"!dist/**/*.spec.*"
	],
	"sideEffects": [
		"**/*.css"
	],
	"svelte": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js"
		}
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@playwright/test": "^1.58.2",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"playwright": "^1.58.2",
		"publint": "^0.3.17",
		"svelte": "^5.49.2",
		"svelte-adapter-bun": "^1.0.1",
		"svelte-check": "^4.3.6",
		"typescript": "^5.9.3",
		"vite": "^7.3.1",
		"vite-plugin-top-level-await": "^1.6.0",
		"vite-plugin-wasm": "^3.5.0",
		"vitest": "^3.0.0",
		"@vitest/coverage-v8": "^3.0.0",
		"happy-dom": "^16.0.0"
	},
	"description": "Modular, local-first block editor engine for Svelte 5, built on a single contenteditable architecture and Loro-CRDT.",
	"author": {
		"name": "Killian Di Vincenzo",
		"url": "https://github.com/killiandvcz"
	},
	"publishConfig": {
		"access": "public"
	},
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/aionbuilders/nabu"
	},
	"homepage": "https://github.com/aionbuilders/nabu#readme",
	"keywords": [
		"svelte",
		"svelte5",
		"editor",
		"block-editor",
		"rich-text",
		"crdt",
		"loro",
		"local-first",
		"collaborative"
	],
	"dependencies": {
		"@aionbuilders/pulse": "^1.0.1",
		"loro-crdt": "^1.10.6"
	}
}
